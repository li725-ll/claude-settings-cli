{
  "name": "claude-settings-cli",
  "version": "1.1.0",
  "description": "CLI tool to manage Claude Code configuration presets",
  "type": "module",
  "bin": {
    "ccc": "bin/ccc.mjs"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "prepublishOnly": "npm run build",
    "release": "standard-version && npm run build && npm publish",
    "release:patch": "standard-version --release-as patch && npm run build && npm publish",
    "release:minor": "standard-version --release-as minor && npm run build && npm publish",
    "release:major": "standard-version --release-as major && npm run build && npm publish"
  },
  "keywords": [
    "claude",
    "claude-code",
    "config",
    "cli",
    "preset"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/li725-ll/claude-settings-cli.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.0.0",
    "inquirer-autocomplete-prompt": "^3.0.1",
    "ora": "^8.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.0",
    "@types/inquirer": "^9.0.9",
    "@types/inquirer-autocomplete-prompt": "^3.0.3",
    "@types/node": "^20.0.0",
    "prettier": "^3.2.0",
    "standard-version": "^9.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
